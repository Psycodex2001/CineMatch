# ──────────────────────────────────────────────────────────────────
# CineMatch — .env.example
#
# Copie este arquivo para ".env" e ajuste os valores conforme necessário.
# O arquivo ".env" NÃO deve ser commitado (adicione ao .gitignore).
# ──────────────────────────────────────────────────────────────────

# ── Banco de dados ─────────────────────────────────────────────────
# SQLite (padrão — ideal para desenvolvimento)
DATABASE_URL=sqlite:///./data/cinematch.db

# PostgreSQL (produção — requer psycopg2-binary no requirements.txt)
# DATABASE_URL=postgresql://cinematch:senha@localhost:5432/cinematch

# ── Dataset ────────────────────────────────────────────────────────
DATASET_REPO=ashraq/ml-latest-small

# ── Hiperparâmetros do modelo ──────────────────────────────────────
# Número de fatores latentes do SVD (maior = mais capacidade, mais lento)
N_SVD_COMPONENTS=50

# Peso da Filtragem Colaborativa no modelo híbrido (0.0 – 1.0)
CF_WEIGHT=0.6

# Peso da Filtragem por Conteúdo (deve ser = 1.0 - CF_WEIGHT)
CB_WEIGHT=0.4

# ── API ────────────────────────────────────────────────────────────
# Número padrão de recomendações por requisição
DEFAULT_TOP_N=10

# Número máximo permitido
MAX_TOP_N=50
